@model StarterM.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "登入";
    Layout = null;
}
<!DOCTYPE html>
<html lang="zh-TW" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - 差旅與碳排管理系統</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="icon" type="image/png" href="/images/logo2.png" />
    <link href="~/css/site.css" rel="stylesheet" />
    <link href="~/css/style.css" rel="stylesheet" />

    <style>
        html, body {
            height: 100%;
            background: #f5f7fb;
        }

        .login-page {
            min-height: 100vh;
            display: flex;
            align-items: flex-start;
            padding: 11rem 0 2rem;
        }

        .login-shell {
            background: rgba(255, 255, 255, 0.75); 
            border-radius: 1rem;
            overflow: hidden;
            box-shadow: 
                0 10px 30px rgba(0,0,0,0.08),
                0 2px 8px rgba(0,0,0,0.04);
            backdrop-filter: blur(6px);
            max-width: 1100px;
            margin: 0 auto;
        }

        .login-left {
            background: #ffffff;
            box-shadow: inset -1px 0 0 #eef2f7;
            padding: 2.5rem 2.2rem;
        }

        .login-right {
            padding: 2.5rem 2.2rem;
            background: linear-gradient(135deg, #f8f7ff 0%, #f1f5ff 100%);
            border-left: 1px solid #eef2f7;
        }

        .login-brand {
            font-weight: 700;
            line-height: 1.3;
            color: #1f2d3d;
        }

        .login-subtitle {
            color: #6c757d;
            margin-bottom: 1.5rem;
        }

        .feature-card {
            background: #ffffff;
            border: 1px solid #eef2f7;
            border-radius: 0.75rem;
            padding: 1rem;
            transition: all 0.2s ease;
        }

        .feature-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 .4rem 1rem rgba(0,0,0,.08);
        }

        .feature-card i {
            margin-bottom: 0.85rem;
        }

        .feature-title {
            font-weight: 700;
            color: #1f2d3d;
            margin-bottom: 0.45rem;
        }

        .feature-text {
            color: #6c757d;
            font-size: 0.92rem;
            margin-bottom: 0;
        }

        .auth-form-title {
            font-weight: 700;
            color: #1f2d3d;
        }

        .auth-form-hint {
            color: #6c757d;
            margin-bottom: 1.5rem;
        }

        .btn-login {
            background: linear-gradient(135deg, #6f42c1, #5a32a3);
            border: none;
            font-weight: 600;
            letter-spacing: 0.5px;
        }
        .btn-login:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(111,66,193,0.3);
        }
        body {
            background: linear-gradient(120deg, #f5f7fb, #e9edff);
        }

        @@media (max-width: 991.98px) {
            .login-right {
                border-left: 0;
                border-top: 1px solid #eef2f7;
            }
            .login-shell {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="container login-page">
        <div class="row justify-content-center w-100">
            <div class="col-xl-12">
                <div class="login-shell">
                    <div class="row no-gutters">
                        <!-- 左側：登入表單 -->
                        <div class="col-lg-5">
                            <div class="login-left h-100">
                                <h2 class="mb-1 font-weight-bold">
                                    <i class="fas fa-suitcase-rolling text-primary mr-2 fa-lg"></i>
                                    差旅與碳排管理系統
                                </h2>
                                <p class="text-muted mb-4">
                                    請登入以進行差旅申請、審核與分析作業。
                                </p>

                                <form asp-action="Login" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                                    <div class="form-group row">
                                        <label asp-for="Email" class="col-sm-3 col-form-label">
                                            <strong>Email</strong>
                                        </label>
                                        <div class="col-sm-9">
                                            <input asp-for="Email" class="form-control form-control-lg" placeholder="請輸入 Email" />
                                            <span asp-validation-for="Email" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="form-group row">
                                        <label asp-for="Password" class="col-sm-3 col-form-label">
                                            <strong>密碼</strong>
                                        </label>
                                        <div class="col-sm-9">
                                            <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="請輸入密碼" />
                                            <span asp-validation-for="Password" class="text-danger"></span>
                                        </div>
                                    </div>

                                    <div class="form-group form-check mt-3 mb-4">
                                        <input asp-for="RememberMe" class="form-check-input" type="checkbox" id="basic_checkbox_1" />
                                        <label asp-for="RememberMe" class="form-check-label" for="basic_checkbox_1">記住我</label>
                                    </div>

                                    <button type="submit" class="btn btn-primary btn-block btn-login">
                                        <i class="fas fa-sign-in-alt mr-1"></i> 登入
                                    </button>
                                    <div class="mt-3 text-center text-muted" style="font-size: 0.92rem;">
                                        Demo：
                                        <a href="javascript:void(0)" class="text-primary font-weight-bold mr-3" onclick="demoLogin('manager')">
                                            Manager
                                        </a>
                                        <a href="javascript:void(0)" class="text-success font-weight-bold" onclick="demoLogin('employee')">
                                            Employee
                                        </a>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <!-- 右側：系統功能介紹 -->
                        <div class="col-lg-7">
                            <div class="login-right h-100">
                                <h3 class="login-brand mb-2">簡化差旅流程，掌握費用與碳排</h3>
                                <p class="login-subtitle">
                                    本系統提供差旅報支、審核管理、費用分析與 ESG 碳排統計，協助企業提升管理效率。
                                </p>

                                <div class="row">
                                    <div class="col-md-4 col-sm-12 mb-3">
                                        <div class="feature-card">
                                            <i class="fas fa-receipt fa-2x text-primary"></i>
                                            <div class="feature-title">差旅報支</div>
                                            <p class="feature-text">整合里程與補助金額計算，簡化申請流程。</p>
                                        </div>
                                    </div>

                                    <div class="col-md-4 col-sm-12 mb-3">
                                        <div class="feature-card">
                                            <i class="fas fa-chart-bar fa-2x text-danger"></i>
                                            <div class="feature-title">數據分析</div>
                                            <p class="feature-text">快速查看差旅費用、交通成本與統計趨勢。</p>
                                        </div>
                                    </div>

                                    <div class="col-md-4 col-sm-12 mb-3">
                                        <div class="feature-card">
                                            <i class="fas fa-leaf fa-2x text-success"></i>
                                            <div class="feature-title">碳排管理</div>
                                            <p class="feature-text">依交通工具與里程掌握碳排放資訊。</p>
                                        </div>
                                    </div>
                                </div>

                                <div class="mt-3 text-muted" style="font-size: 0.95rem;">
                                    適用角色：員工申請、主管審核、管理分析
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
   </div>
</body>
</html>

<script>
    function demoLogin(role) {
        if (role === 'manager') {
            document.getElementById('Email').value = 'manager.demo@travel.com';
            document.getElementById('Password').value = 'DemoManager123!';
        } else {
            document.getElementById('Email').value = 'employee.chen.demo@travel.com';
            document.getElementById('Password').value = 'DemoEmployee123!';
        }
    }
</script>
