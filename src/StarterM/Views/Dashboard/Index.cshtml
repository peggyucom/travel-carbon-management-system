@{
    ViewData["Title"] = "費用與碳排分析";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row page-titles mx-0">
    <div class="col-sm-12 p-md-0">
        <div class="welcome-text">
            <h1><i class="text-primary fa-lg mr-2 icon icon-chart-pie-36"></i>費用與碳排分析</h1>
            <div class="mt-3">
                <h5 id="currentRangeLabel"></h5>
            </div>             
        </div>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center">
            <div class="btn-group flex-wrap mb-3 mb-lg-0" role="group" aria-label="時間篩選">
                <button type="button" class="btn btn-outline-primary filter-btn active" data-range="month">本月</button>
                <button type="button" class="btn btn-outline-primary filter-btn" data-range="quarter">本季</button>
                <button type="button" class="btn btn-outline-primary filter-btn" data-range="year">今年</button>
                <button type="button" class="btn btn-outline-primary filter-btn" data-range="custom">自訂區間</button>
            </div>

            <div class="custom-filter-panel" id="customFilterPanel">
                <div class="form-row align-items-end">
                    <div class="col-sm-5">
                        <label class="small text-muted mb-1" for="startDate">開始日期</label>
                        <input type="date" id="startDate" class="form-control" />
                    </div>
                    <div class="col-sm-5">
                        <label class="small text-muted mb-1" for="endDate">結束日期</label>
                        <input type="date" id="endDate" class="form-control" />
                    </div>
                    <div class="col-sm-2 mt-3 mt-sm-0">
                        <button type="button" id="applyCustomRange" class="btn btn-primary btn-block">
                            <i class="fas fa-sync-alt"></i> 套用
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-lg-4 col-sm-6 mb-3">
        <div class="card kpi-card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="kpi-label">總差旅費用</div>
                <div class="kpi-value" id="kpiTotalTravelCost">NT$ 0</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-sm-6 mb-3">
        <div class="card kpi-card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="kpi-label">總碳排放量</div>
                <div class="kpi-value" id="kpiCarbonEmission">0 kg CO₂</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4 col-sm-6 mb-3">
        <div class="card kpi-card shadow-sm h-100 border-0">
            <div class="card-body">
                <div class="kpi-label">出差天數</div>
                <div class="kpi-value" id="kpiTravelDays">0 天</div>
            </div>
        </div>
    </div>
</div>

<div class="alert alert-danger d-none" id="dashboardError"></div>

<div class="row">
    <div class="col-12 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex align-items-center">
                <h3 class="mb-0 d-flex align-items-center">
                    <i class="fas fa-project-diagram text-primary mr-2"></i>
                    交通成本與碳排關係
                </h3>
            </div>
            <div class="card-body">
                <div class="chart-fixed-wrapper scatter-chart-wrapper">
                    <canvas id="transportCostCarbonChart"></canvas>
                    <div class="chart-empty-state d-none" id="transportCostCarbonChartEmpty"></div>
                </div>
                <div class="alert alert-light border-left border-primary mt-3 mb-0">
                    此圖顯示不同交通工具在費用與碳排上的分布，可用於判斷高成本是否伴隨高碳排，或存在較佳的替代方案。
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex align-items-center">
                <h3 class="mb-0 d-flex align-items-center">
                    <i class="fas fa-medal text-primary mr-2"></i>
                    員工費用排行
                </h3>
            </div>
            <div class="card-body">
                <div class="chart-fixed-wrapper ranking-chart-wrapper">
                    <canvas id="employeeExpenseChart"></canvas>
                    <div class="chart-empty-state d-none" id="employeeExpenseChartEmpty"></div>
                </div>
                <div class="chart-hint">點擊員工長條可開啟差旅明細頁。</div>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex align-items-center">
                <h3 class="mb-0 d-flex align-items-center">
                    <i class="fas fa-leaf text-primary mr-2"></i>
                    員工碳排行
                </h3>
            </div>
            <div class="card-body">
                <div class="chart-fixed-wrapper ranking-chart-wrapper">
                    <canvas id="employeeCarbonChart"></canvas>
                    <div class="chart-empty-state d-none" id="employeeCarbonChartEmpty"></div>
                </div>
                <div class="chart-hint">點擊員工長條可開啟差旅明細頁。</div>
            </div>
        </div>
    </div>

    <div class="col-12 mb-4">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white d-flex align-items-center">
                <h3 class="mb-0 d-flex align-items-center">
                    <i class="fas fa-chart-area text-primary mr-2"></i>
                    交通成本與碳排趨勢
                </h3>
            </div>
            <div class="card-body">
                <div class="chart-fixed-wrapper dual-trend-chart-wrapper">
                    <canvas id="costCarbonTrendChart"></canvas>
                    <div class="chart-empty-state d-none" id="costCarbonTrendChartEmpty"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .custom-filter-panel {
            display: none;
            width: 100%;
            max-width: 520px;
        }

        .kpi-card {
            background: linear-gradient(135deg, #ffffff 0%, #f7f9fc 100%);
        }

        .kpi-label {
            color: #6c757d;
            font-size: 0.95rem;
            margin-bottom: 0.5rem;
        }

        .kpi-value {
            font-size: 1.9rem;
            font-weight: 700;
            color: #1f2d3d;
        }

        .chart-hint {
            color: #6c757d;
            font-size: 0.875rem;
            margin-top: 0.75rem;
        }

        .chart-fixed-wrapper {
            position: relative;
            width: 100%;
        }

        .dual-trend-chart-wrapper {
            height: 340px;
        }

        .scatter-chart-wrapper {
            height: 460px;
        }

        .ranking-chart-wrapper {
            height: 320px;
        }

        .chart-fixed-wrapper canvas {
            width: 100% !important;
            height: 100% !important;
            display: block;
        }

        .chart-empty-state {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 1.25rem;
            color: #6c757d;
            background: linear-gradient(135deg, rgba(248, 250, 252, 0.96) 0%, rgba(255, 255, 255, 0.96) 100%);
            border: 1px dashed #d6dde5;
            border-radius: 0.5rem;
        }
    </style>
}

@section Scripts {   
    <script>

        Chart.register(ChartDataLabels);

        @* 存每一張圖（避免重複建立） *@
        const charts = {
            costCarbonTrend: null,
            transportCostCarbon: null,
            employeeExpense: null,
            employeeCarbon: null
        };

        @* 記住現在選的是「本月 / 本季 / 自訂」 *@
        const dashboardState = {
            preset: 'month',
            startDate: null,
            endDate: null,
            dashboardRequestId: 0
        };

        const chartPalette = ['#2563eb', '#16a34a', '#f59e0b', '#dc2626', '#8b5cf6', '#06b6d4', '#64748b'];

        @* 定義顏色 *@
        const transportColorMap = {
            '高鐵': '#2563eb',
            '火車': '#16a34a',
            '台鐵': '#16a34a',
            '捷運': '#0f766e',
            '公車': '#0891b2',
            '客運': '#0284c7',
            '計程車': '#f59e0b',
            'Taxi': '#f59e0b',
            '自用車': '#dc2626',
            '汽車': '#dc2626',
            '私家車': '#dc2626',
            '機車': '#7c3aed',
            '摩托車': '#7c3aed',
            '飛機': '#9333ea',
            '步行': '#64748b'
        };

        @* 有定義:用指定顏色，沒定義:用 hash 算一個固定顏色 *@
        function getStableColor(key, presetMap) {
            if (presetMap[key]) {
                return presetMap[key];
            }

            const normalized = String(key || '').trim();
            let hash = 0;
            for (let index = 0; index < normalized.length; index += 1) {
                hash = ((hash << 5) - hash) + normalized.charCodeAt(index);
                hash |= 0;
            }

            return chartPalette[Math.abs(hash) % chartPalette.length];
        }

        @* 格式化 *@
        function formatDateForApi(date) {
            const year = date.getFullYear();
            const month = String(date.getMonth() + 1).padStart(2, '0');
            const day = String(date.getDate()).padStart(2, '0');
            return `${year}-${month}-${day}`;
        }

        function parseInputDate(value) {
            const [year, month, day] = value.split('-').map(Number);
            return new Date(year, month - 1, day);
        }

        function formatCurrency(value) {
            return `NT$ ${Number(value || 0).toLocaleString('zh-TW', {
                minimumFractionDigits: 0,
                maximumFractionDigits: 0
            })}`;
        }

        function formatCarbon(value) {
            return `${Number(value || 0).toLocaleString('zh-TW', {
                minimumFractionDigits: 0,
                maximumFractionDigits: 2
            })} kg CO₂`;
        }

        function getQuarterNumber(date) {
            return Math.floor(date.getMonth() / 3) + 1;
        }

        function getRangeSummary() {
            if (!dashboardState.startDate || !dashboardState.endDate) {
                return '';
            }

            if (dashboardState.preset === 'month') {
                return `本月 (${dashboardState.startDate.getFullYear()} 年 ${dashboardState.startDate.getMonth() + 1} 月)`;
            }

            if (dashboardState.preset === 'quarter') {
                const quarterLabel = `本季 (${dashboardState.startDate.getFullYear()} 年 Q${getQuarterNumber(dashboardState.startDate)})`;
                const monthRange = getPresetRange('month');
                const isSameAsMonth =
                    dashboardState.startDate.getTime() === monthRange.startDate.getTime() &&
                    dashboardState.endDate.getTime() === monthRange.endDate.getTime();

                return isSameAsMonth
                    ? `${quarterLabel}，目前為季度首月，區間與本月相同`
                    : quarterLabel;
            }

            if (dashboardState.preset === 'year') {
                return `今年 (${dashboardState.startDate.getFullYear()} 年)`;
            }

            return '自訂區間';
        }

        function destroyChart(chart) {
            if (chart instanceof Chart) {
                chart.destroy();
            }
        }

        function toggleChartEmptyState(canvasSelector, emptySelector, message) {
            const $canvas = $(canvasSelector);
            const $emptyState = $(emptySelector);

            if (message) {
                $canvas.addClass('d-none');
                $emptyState.removeClass('d-none').text(message);
                return;
            }

            $emptyState.addClass('d-none').text('');
            $canvas.removeClass('d-none');
        }

        async function apiGet(url, params) {
            const response = await $.get(url, params);
            if (!response.success) {
                throw new Error(response.error?.message || '資料讀取失敗');
            }

            return response.data;
        }

        function getPresetRange(preset) {
            const today = new Date();
            today.setHours(0, 0, 0, 0);

            if (preset === 'month') {
                return {
                    startDate: new Date(today.getFullYear(), today.getMonth(), 1),
                    endDate: today
                };
            }

            if (preset === 'quarter') {
                const quarterStartMonth = Math.floor(today.getMonth() / 3) * 3;
                return {
                    startDate: new Date(today.getFullYear(), quarterStartMonth, 1),
                    endDate: today
                };
            }

            return {
                startDate: new Date(today.getFullYear(), 0, 1),
                endDate: today
            };
        }

        function setPreset(preset) {
            dashboardState.preset = preset;

            $('.filter-btn').removeClass('active btn-primary').addClass('btn-outline-primary');
            $(`.filter-btn[data-range="${preset}"]`).removeClass('btn-outline-primary').addClass('active btn-primary');

            if (preset === 'custom') {
                $('#customFilterPanel').stop(true, true).slideDown(150);
                return;
            }

            $('#customFilterPanel').stop(true, true).slideUp(150);

            const range = getPresetRange(preset);
            dashboardState.startDate = range.startDate;
            dashboardState.endDate = range.endDate;
            $('#startDate').val(formatDateForApi(range.startDate));
            $('#endDate').val(formatDateForApi(range.endDate));
            void loadDashboard();
        }

        function updateRangeLabel() {
            if (!dashboardState.startDate || !dashboardState.endDate) {
                $('#currentRangeLabel').text('');
                return;
            }

            $('#currentRangeLabel').text(
                `統計區間：${getRangeSummary()}，${formatDateForApi(dashboardState.startDate)} ～ ${formatDateForApi(dashboardState.endDate)}`
            );
        }

        function renderKpis(kpi) {
            $('#kpiTotalTravelCost').text(formatCurrency(kpi.totalTravelCost));
            $('#kpiCarbonEmission').text(formatCarbon(kpi.totalCarbonEmission));
            $('#kpiTravelDays').text(`${Number(kpi.travelDays || 0).toLocaleString('zh-TW')} 天`);
        }

        @*  API回來的資料轉成圖:destroy舊圖（避免疊圖）、判斷有沒有資料、建立 Chart.js  *@
        function renderCostCarbonTrendChart(items) {
            destroyChart(charts.costCarbonTrend);

            if (!items.length) {
                toggleChartEmptyState('#costCarbonTrendChart', '#costCarbonTrendChartEmpty', '目前區間沒有交通成本與碳排資料，無法顯示雙軸趨勢。');
                return;
            }

            toggleChartEmptyState('#costCarbonTrendChart', '#costCarbonTrendChartEmpty', null);

            const isSinglePoint = items.length === 1;

            charts.costCarbonTrend = new Chart(document.getElementById('costCarbonTrendChart'), {
                type: 'line',
                data: {
                    labels: items.map(item => item.month),
                    datasets: [
                        {
                            label: '交通費用',
                            data: items.map(item => item.transportationCost),
                            borderColor: '#2563eb',
                            backgroundColor: 'rgba(37, 99, 235, 0.12)',
                            tension: 0.25,
                            pointRadius: isSinglePoint ? 7 : 4,
                            pointHoverRadius: isSinglePoint ? 10 : 6,
                            yAxisID: 'costAxis'
                        },
                        {
                            label: '碳排放量',
                            data: items.map(item => item.carbonEmission),
                            borderColor: '#16a34a',
                            backgroundColor: 'rgba(22, 163, 74, 0.12)',
                            tension: 0.25,
                            pointRadius: isSinglePoint ? 7 : 4,
                            pointHoverRadius: isSinglePoint ? 10 : 6,
                            yAxisID: 'carbonAxis'
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'index',
                        intersect: false
                    },
                    plugins: {
                        datalabels: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return context.dataset.yAxisID === 'costAxis'
                                        ? `${context.dataset.label}: ${formatCurrency(context.raw)}`
                                        : `${context.dataset.label}: ${formatCarbon(context.raw)}`;
                                }
                            }
                        }
                    },
                    scales: {
                        costAxis: {
                            type: 'linear',
                            position: 'left',
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: '交通費用 (NT$)'
                            }
                        },
                        carbonAxis: {
                            type: 'linear',
                            position: 'right',
                            beginAtZero: true,
                            grid: {
                                drawOnChartArea: false
                            },
                            title: {
                                display: true,
                                text: '碳排放量 (kg CO₂)'
                            }
                        }
                    }
                }
            });
        }

        function renderTransportCostCarbonChart(items) {
            destroyChart(charts.transportCostCarbon);

            if (!items.length) {
                toggleChartEmptyState('#transportCostCarbonChart', '#transportCostCarbonChartEmpty', '目前區間沒有交通成本與碳排資料，無法顯示關聯分析。');
                return;
            }

            toggleChartEmptyState('#transportCostCarbonChart', '#transportCostCarbonChartEmpty', null);

            charts.transportCostCarbon = new Chart(document.getElementById('transportCostCarbonChart'), {
                type: 'scatter',
                data: {
                    datasets: items.map(item => ({
                        label: item.transportType,
                        data: [{
                            x: item.totalExpense,
                            y: item.totalCarbon,
                            transportType: item.transportType
                        }],
                        pointRadius: 7,
                        pointHoverRadius: 9,
                        backgroundColor: getStableColor(item.transportType, transportColorMap),
                        borderColor: getStableColor(item.transportType, transportColorMap)
                    }))
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    parsing: false,
                    plugins: {
                        legend: {
                            display: true,
                            position: 'bottom'
                        },
                        datalabels: {
                            display: false
                        },
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    const point = context.raw;
                                    return `${point.transportType}: ${formatCurrency(point.x)} / ${formatCarbon(point.y)}`;
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: '交通費用 (NT$)'
                            }
                        },
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: '碳排放量 (kg CO₂)'
                            }
                        }
                    }
                }
            });
        }

        function openEmployeeDetail(employeeId, view) {
            const params = new URLSearchParams({
                employeeId,
                view,
                startDate: formatDateForApi(dashboardState.startDate),
                endDate: formatDateForApi(dashboardState.endDate)
            });

            window.location.href = `/Dashboard/EmployeeDetail?${params.toString()}`;
        }

        function renderRankingChart(chartKey, selector, items, label, valueKey, color, formatter, emptyMessage, detailView) {
            destroyChart(charts[chartKey]);

            const emptySelector = `${selector}Empty`;
            if (!items.length) {
                toggleChartEmptyState(selector, emptySelector, emptyMessage);
                return;
            }

            toggleChartEmptyState(selector, emptySelector, null);

            charts[chartKey] = new Chart(document.querySelector(selector), {
                type: 'bar',
                data: {
                    labels: items.map(item => item.employeeName),
                    datasets: [{
                        label,
                        data: items.map(item => item[valueKey]),
                        backgroundColor: color,
                        maxBarThickness: 28,
                        categoryPercentage: 0.72,
                        barPercentage: 0.9,
                        borderRadius: 6,
                        borderSkipped: false
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    indexAxis: 'y',
                    layout: {
                        padding: {
                            right: 60
                        }
                    },
                    onClick: function (event, elements) {
                        if (!elements.length) {
                            return;
                        }

                        const selected = items[elements[0].index];
                        openEmployeeDetail(selected.employeeId, detailView);
                    },
                    plugins: {
                        tooltip: {
                            callbacks: {
                                label: function (context) {
                                    return formatter(context.raw);
                                }
                            }
                        },
                        datalabels: {
                            anchor: 'end',
                            align: 'end',
                            offset: 4,
                            clamp: true,
                            clip: false,
                            color: '#495057',
                            font: {
                                weight: 'bold',
                                size: 11
                            },
                            formatter: function (value) {
                                return formatter(value);
                            }
                        }
                    },
                    scales: {
                        x: {
                            beginAtZero: true,
                            grace: '10%'
                        }
                    }
                }
            });
        }

        function renderDashboardError(message) {
            $('#dashboardError').removeClass('d-none').text(message);
        }

        function clearDashboardError() {
            $('#dashboardError').addClass('d-none').text('');
        }


        @* 總開關：打 API（一次打 8 個）、拿資料、丟給各個 render *@
        async function loadDashboard() {
            const requestId = ++dashboardState.dashboardRequestId;

            if (!dashboardState.startDate || !dashboardState.endDate) {
                return;
            }

            clearDashboardError();
            updateRangeLabel();

            try {
                const requestParams = {
                    startDate: formatDateForApi(dashboardState.startDate),
                    endDate: formatDateForApi(dashboardState.endDate),
                    limit: 10
                };

                const [kpi, costCarbonTrend, transportCostCarbon, employeeExpense, employeeCarbon] = await Promise.all([
                    apiGet('/api/dashboard/kpi', requestParams),
                    apiGet('/api/dashboard/cost-carbon-trend', requestParams),
                    apiGet('/api/dashboard/transport-cost-carbon', requestParams),
                    apiGet('/api/dashboard/employee-expense-ranking', requestParams),
                    apiGet('/api/dashboard/employee-carbon-ranking', requestParams)
                ]);

                if (requestId !== dashboardState.dashboardRequestId) {
                    return;
                }

                renderKpis(kpi);
                renderCostCarbonTrendChart(costCarbonTrend);
                renderTransportCostCarbonChart(transportCostCarbon);
                renderRankingChart(
                    'employeeExpense',
                    '#employeeExpenseChart',
                    employeeExpense,
                    '費用',
                    'totalExpense',
                    'rgba(37, 99, 235, 0.75)',
                    formatCurrency,
                    '目前區間沒有可排名的員工費用資料。',
                    'cost'
                );
                renderRankingChart(
                    'employeeCarbon',
                    '#employeeCarbonChart',
                    employeeCarbon,
                    '碳排',
                    'totalCarbon',
                    'rgba(22, 163, 74, 0.75)',
                    formatCarbon,
                    '目前區間沒有可排名的員工碳排資料。',
                    'carbon'
                );
            } catch (error) {
                if (requestId !== dashboardState.dashboardRequestId) {
                    return;
                }

                renderDashboardError(error.message || '儀表板資料載入失敗');
            }
        }

        $(function () {
            const initialRange = getPresetRange('month');
            $('#startDate').val(formatDateForApi(initialRange.startDate));
            $('#endDate').val(formatDateForApi(initialRange.endDate));

            $('.filter-btn').on('click', function () {
                setPreset($(this).data('range'));
            });

            $('#applyCustomRange').on('click', function () {
                const startValue = $('#startDate').val();
                const endValue = $('#endDate').val();

                if (!startValue || !endValue) {
                    renderDashboardError('請完整選擇開始日期與結束日期。');
                    return;
                }

                const startDate = parseInputDate(startValue);
                const endDate = parseInputDate(endValue);

                if (startDate > endDate) {
                    renderDashboardError('開始日期不可晚於結束日期。');
                    return;
                }

                dashboardState.startDate = startDate;
                dashboardState.endDate = endDate;
                clearDashboardError();
                void loadDashboard();
            });

            @* 時間篩選 *@
            setPreset('month');
        });
    </script>
}
