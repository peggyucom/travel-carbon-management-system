@model StarterM.ViewModels.ExpenseCreateViewModel
@{
    // 頁面標題
    ViewData["Title"] = "新增費用明細";

    // 套用共用版型
    Layout = "~/Views/Shared/_Layout.cshtml";

    // 從 Controller 傳來的制度參數
    var mealRate = (decimal)ViewData["MealAllowanceDailyRate"]!;
    var carRate = ViewData["CarAllowancePerKm"] as decimal? ?? 5m;

    // 從 Controller 傳來的費用分類清單
    var categories = ViewData["ExpenseCategories"] as List<StarterM.Models.ExpenseCategory> ?? new List<StarterM.Models.ExpenseCategory>();
}

@section Styles {
<style>
    /* ===== 表單寬度 ===== */
    .basic-form {
        max-width: 800px;   
        margin: 0 auto;
    }

    /* 當顯示地圖時，取消 max-width 使左右欄能佔滿容器 */
    .basic-form.wide {
        max-width: 1200px;
        width: 100%;
        margin: 0 auto;
    }

    /* 讓上方固定功能列維持在 Leaflet 地圖圖層之上 */
    #main-wrapper .header {
        z-index: 1100;
    }

    #main-wrapper .nav-header {
        z-index: 1101;
    }
</style>
}

<!-- =========================================================
     1. 頁面標題區：顯示功能名稱、差旅日期與事由
     ========================================================= -->
<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h1><i class="fas fa-plus-square text-primary fa-lg mr-2"></i>新增費用明細</h1> 
            <div class="text-muted">
                <h4>日期：@ViewData["TripDate"] ｜ 事由：@ViewData["TripReason"]</h4>
            </div>
        </div>
    </div>
</div>

<!-- =========================================================
     2. 主畫面區：新增費用表單 + 右側地圖區
     ========================================================= -->
<div class="card">            
    <div class="card-body">
        <div class="basic-form">
            <form asp-action="AddExpense" method="post" id="expenseForm">
                @Html.AntiForgeryToken()

                <!--
                    隱藏欄位：
                    1. DailyTripId：這筆費用屬於哪一筆差旅
                    2. 起終點座標：若使用地圖選點或地址定位，會把座標一起帶回後端，
                       讓後端可直接算距離，不必只依賴文字地址再查一次。
                -->
                <input type="hidden" asp-for="DailyTripId" />
                <input type="hidden" asp-for="OriginLatitude" id="originLatitudeInput" />
                <input type="hidden" asp-for="OriginLongitude" id="originLongitudeInput" />
                <input type="hidden" asp-for="DestinationLatitude" id="destinationLatitudeInput" />
                <input type="hidden" asp-for="DestinationLongitude" id="destinationLongitudeInput" />

                <div class="row">
                    <!-- =========================
                         左側：費用輸入表單
                         ========================= -->
                    <div id="formColumn" class="col-md-12">
                        <!-- 費用分類 -->
                        <div class="form-group">
                            <label asp-for="ExpenseCategoryId" class="col-form-label col-form-label-lg">費用分類</label>
                            <select asp-for="ExpenseCategoryId" class="form-control form-control-lg" id="expenseCategorySelect">
                                <option value="">-- 請選擇 --</option>
                                @foreach (var cat in categories)
                                {
                                    <option value="@cat.Id" data-code="@cat.Code">@cat.Name</option>
                                }
                            </select>
                            <span asp-validation-for="ExpenseCategoryId" class="text-danger"></span>
                        </div>

                        <!-- 費用項目：會依使用者選到的分類，透過 AJAX 動態載入 -->
                        <div class="form-group" id="expenseItemSection" style="display:none;">
                            <label asp-for="ExpenseItemId" class="col-form-label col-form-label-lg">費用項目</label>
                            <select asp-for="ExpenseItemId" class="form-control form-control-lg" id="expenseItemSelect">
                                <option value="">-- 請選擇 --</option>
                            </select>
                            <span asp-validation-for="ExpenseItemId" class="text-danger"></span>
                        </div>

                        <!-- 起點 / 終點：只有交通類費用才會顯示 -->
                        <div id="locationSection" style="display:none;">
                            <div class="form-text text-primary">
                                <i class="fas fa-info-circle"></i> 「輸入地址後請按放大鏡搜尋定位」 或 「直接在地圖上點擊設定起點及終點」
                            </div>
                            <div class="form-group">
                                <label asp-for="Origin" class="col-form-label col-form-label-lg">起點</label>
                                <div class="input-group">
                                    <input asp-for="Origin" class="form-control form-control-lg" id="originInput" />
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-primary" onclick="geocodeAddress('origin')">
                                            <i class="fas fa-search"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label asp-for="Destination" class="col-form-label col-form-label-lg">終點</label>
                                <div class="input-group">
                                    <input asp-for="Destination" class="form-control form-control-lg" id="destinationInput" />
                                    <div class="input-group-append">
                                        <button type="button" class="btn btn-outline-primary" onclick="geocodeAddress('destination')">
                                            <i class="fas fa-search"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <!--
                                按下後會呼叫本站 /api/expense/route-preview。
                                前端不直接碰外部 OSM / OSRM，而是由後端統一代理。
                            -->
                            <button type="button" class="btn btn-primary btn-sm mb-2" onclick="calculateRoute()">
                                <i class="fas fa-route"></i> 計算路線距離
                            </button>
                        </div>

                        <!-- 往返勾選：用來決定距離是否乘 2 -->
                        <div class="form-check mb-3" id="roundTripSection" style="display:none;">
                            <input asp-for="IsRoundTrip" class="form-check-input" type="checkbox" id="isRoundTripCheck" checked />
                            <label class="form-check-label" for="isRoundTripCheck">往返（自動計算來回）</label>
                        </div>

                        <!--
                            公里數是系統試算結果，不允許手動輸入。
                            使用者必須先按「計算路線距離」，欄位才會有值。
                        -->
                        <div class="form-group" id="distanceSection" style="display:none;">
                            <label asp-for="DistanceKm" class="col-form-label col-form-label-lg">公里數 (系統計算)</label>
                            <input asp-for="DistanceKm" class="form-control form-control-lg" type="number" step="0.1" min="0.1" max="1000" id="distanceInput" readonly />
                            <span asp-validation-for="DistanceKm" class="text-danger"></span>
                        </div>

                        <!-- 金額：膳雜費 / 自用車會由系統自動帶入或重算 -->
                        <div class="form-group" id="amountSection">
                            <label asp-for="Amount" class="col-form-label col-form-label-lg">金額 (NT$)</label>
                            <input asp-for="Amount" class="form-control form-control-lg" type="number" step="1" min="1" max="100000" id="amountInput" />
                            <span asp-validation-for="Amount" class="text-danger"></span>

                            <!-- 膳雜費提示 -->
                            <div id="mealRateHint" class="form-text text-primary" style="display:none;">
                                膳雜費系統自動帶入 NT$ @((int)mealRate)，不可修改。
                            </div>

                            <!-- 自用車每公里費率提示 -->
                            <div id="carRateHint" class="form-text text-primary" style="display:none;">
                                目前費率：@((int)carRate) 元 / 公里
                            </div>
                        </div>

                        <!-- 說明欄位：Other 類別或地圖選點時可能變成必填 -->
                        <div class="form-group">
                            <label asp-for="Description" class="col-form-label col-form-label-lg" id="descriptionLabel">說明（選填）</label>
                            <input asp-for="Description" class="form-control form-control-lg" id="descriptionInput" />
                            <span asp-validation-for="Description" class="text-danger"></span>

                            <!-- 若起點或終點是地圖選點，提醒使用者補充實際地點 -->
                            <div id="mapPointHint" class="form-text text-danger" style="display:none;">
                                起點或終點為地圖選點，請填寫實際起迄點說明
                            </div>
                        </div>

                        <!-- 操作按鈕 -->
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary mr-2">
                                <i class="fas fa-save"></i> 儲存
                            </button>
                            <a asp-action="TripDetails" asp-route-id="@Model.DailyTripId" class="btn btn-primary">
                                <i class="fas fa-arrow-left"></i> 返回明細
                            </a>
                        </div>
                    </div>

                    <!-- =========================
                         右側：地圖顯示區
                         只有交通類費用才會展開
                         ========================= -->
                    <div id="mapColumn" class="col-md-6 d-none">
                        <div id="mapContainer" style="display:none;">
                            <p class="text-muted small mb-1">
                                <i class="fas fa-map-marked-alt"></i> 使用 OpenStreetMap 開放資料
                            </p>
                            <div id="map" style="height: 400px; border-radius: 8px;"></div>
                            <div id="routeInfo" class="mt-2 text-info font-weight-bold" style="display:none;"></div>
                            <p class="text-muted small mt-2">
                                參考：苗栗縣泰興國小差旅費紀錄系統 曾明傑 設計開發 | 改編自 OpenStreetMap 與 OSRM 開源資源
                            </p>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Leaflet 地圖套件 -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
    // =========================================================
    // 3. 前端互動腳本：控制畫面顯示、地圖選點、路線計算
    // =========================================================

    // 地圖 / 標記 / 路線圖層：
    // map：Leaflet 地圖本體
    // originMarker / destMarker：起點 / 終點 marker
    // routeLayer：畫在地圖上的路線
    let map, originMarker, destMarker, routeLayer;

    // 起訖點經緯度。
    // 當使用者完成定位或地圖選點後，會把座標暫存在這裡。
    let originCoords = null, destCoords = null;

    // 目前正在設定哪一個點（保留擴充用途）
    let currentSelectingPoint = null;

    // 從 Razor 帶進來的制度參數
    const mealRate = @((int)mealRate);
    const carRate = @((int)carRate);

    // 目前路線是否已重新計算完成。
    // 起終點一變更就會被清成 false，提醒使用者重新試算。
    let routeCalculated = false;

    // 目前選到的費用分類 / 項目代碼
    let currentCategoryCode = '';
    let currentItemCode = '';

    // =========================================================
    // 3-1. 頁面初始化
    // =========================================================
    document.addEventListener('DOMContentLoaded', function () {
        // 建立地圖，預設中心點在台北
        map = L.map('map').setView([25.033, 121.565], 12);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        // 點地圖時跳出「設為起點 / 終點」選單
        map.on('click', function (e) {
            showMapPopup(e.latlng);
        });

        // 綁定畫面事件：
        // - 類別 / 項目改變時，動態調整欄位
        // - 起終點文字被手動改動時，清掉舊座標與舊路線
        document.getElementById('expenseCategorySelect').addEventListener('change', onCategoryChange);
        document.getElementById('expenseItemSelect').addEventListener('change', onItemChange);
        document.getElementById('originInput').addEventListener('input', () => clearPointSelection('origin'));
        document.getElementById('destinationInput').addEventListener('input', () => clearPointSelection('destination'));

        // 載入時先跑一次，處理回填資料的畫面狀態
        onCategoryChange();

        // 若表單因驗證錯誤被重新顯示，hidden input 裡可能還有上次選過的座標，
        // 這裡把它們還原到地圖上。
        restoreSavedPoints();
    });

    // =========================================================
    // 3-2. 切換費用分類時的處理
    // =========================================================
    async function onCategoryChange() {
        const select = document.getElementById('expenseCategorySelect');
        const categoryId = select.value;
        const selectedOption = select.options[select.selectedIndex];
        currentCategoryCode = selectedOption?.dataset?.code || '';

        const isDomesticTransport = currentCategoryCode === 'DomesticTransport';
        const isMeal = currentCategoryCode === 'MealAllowance';
        const isOther = currentCategoryCode === 'Other';

        // 載入費用項目：
        // 這裡打的是本站 MVC action，只是取本系統資料庫中的費用項目，
        // 和外部地圖服務無關。
        const itemSelect = document.getElementById('expenseItemSelect');
        itemSelect.innerHTML = '<option value="">-- 請選擇 --</option>';

        if (categoryId) {
            try {
                const resp = await fetch('/Expense/GetExpenseItems?categoryId=' + categoryId);
                const items = await resp.json();
                items.forEach(item => {
                    const opt = document.createElement('option');
                    opt.value = item.id;
                    opt.textContent = item.name;
                    opt.dataset.code = item.code;
                    itemSelect.appendChild(opt);
                });

                // 如果只有一個項目，就自動選起來，並隱藏下拉選單
                if (items.length === 1) {
                    itemSelect.value = items[0].id;
                    document.getElementById('expenseItemSection').style.display = 'none';
                } else {
                    document.getElementById('expenseItemSection').style.display = '';
                }
            } catch (e) {
                console.error('載入費用項目失敗', e);
            }
        } else {
            document.getElementById('expenseItemSection').style.display = 'none';
        }

        // 膳雜費：金額由系統自動帶入且不可修改
        if (isMeal) {
            document.getElementById('amountInput').value = mealRate;
            document.getElementById('amountInput').readOnly = true;
            document.getElementById('mealRateHint').style.display = '';
        } else {
            document.getElementById('amountInput').readOnly = false;
            document.getElementById('mealRateHint').style.display = 'none';
        }

        // Other 類別：說明改成必填
        const descInput = document.getElementById('descriptionInput');
        if (isOther) {
            document.getElementById('descriptionLabel').textContent = '說明（必填）';
            descInput.required = true;
            descInput.placeholder = '例如:雞精-客戶住院開刀';
        } else {
            document.getElementById('descriptionLabel').textContent = '說明（選填）';
            descInput.required = false;
            descInput.placeholder = '';
        }

        // 不是交通類時，隱藏所有交通欄位
        if (!isDomesticTransport) {
            hideAllTransportSections();
        }

        document.getElementById('carRateHint').style.display = 'none';
        onItemChange();
    }

    // =========================================================
    // 3-3. 切換費用項目時的處理
    // =========================================================
    function onItemChange() {
        const select = document.getElementById('expenseItemSelect');
        const selectedOption = select.options[select.selectedIndex];
        currentItemCode = selectedOption?.dataset?.code || '';

        const isDomesticTransport = currentCategoryCode === 'DomesticTransport';
        if (!isDomesticTransport) {
            hideAllTransportSections();
            return;
        }

        // 自用車和其他交通工具的差異：
        // 自用車金額會依「距離 * 每公里費率」自動計算。
        const isCar = currentItemCode === 'PersonalCar';
        const showMap = isDomesticTransport && currentItemCode !== '';
        const showDistance = showMap;
        const showLocation = showMap;
        const distanceInput = document.getElementById('distanceInput');

        // 控制地圖區域顯示與欄位版面切換
        document.getElementById('mapContainer').style.display = showMap ? '' : 'none';

        // 調整欄位寬度：有地圖時左右各半，無地圖時表單佔滿
        const formCol = document.getElementById('formColumn');
        const mapCol = document.getElementById('mapColumn');
        if (showMap) {
            formCol.classList.remove('col-md-12');
            formCol.classList.add('col-md-6');
            mapCol.classList.remove('d-none');
            mapCol.classList.add('col-md-6');
            const wrapper = document.querySelector('.basic-form');
            if (wrapper) wrapper.classList.add('wide');
        } else {
            formCol.classList.remove('col-md-6');
            formCol.classList.add('col-md-12');
            mapCol.classList.add('d-none');
            mapCol.classList.remove('col-md-6');
            const wrapper = document.querySelector('.basic-form');
            if (wrapper) wrapper.classList.remove('wide');
        }

        // 控制交通欄位顯示
        document.getElementById('locationSection').style.display = showLocation ? '' : 'none';
        document.getElementById('distanceSection').style.display = showDistance ? '' : 'none';
        document.getElementById('roundTripSection').style.display = showDistance ? '' : 'none';
        distanceInput.required = false;
        distanceInput.readOnly = true;

        // 自用車：金額由公里數 * 費率自動計算
        if (isCar) {
            document.getElementById('amountInput').readOnly = true;
            document.getElementById('carRateHint').style.display = '';
        } else {
            document.getElementById('amountInput').readOnly = false;
            document.getElementById('carRateHint').style.display = 'none';
        }

        // 顯示地圖後要重新計算尺寸，不然可能渲染不完整(display: none;會以為尺寸是 0)
        if (showMap) {
            setTimeout(() => map.invalidateSize(), 200); //等畫面「真的出現」再重算
        }

        checkMapPointDescription();
    }

    // =========================================================
    // 3-4. 隱藏所有交通相關區塊
    // =========================================================
    function hideAllTransportSections() {
        document.getElementById('mapContainer').style.display = 'none';
        document.getElementById('locationSection').style.display = 'none';
        document.getElementById('distanceSection').style.display = 'none';
        document.getElementById('roundTripSection').style.display = 'none';

        // 恢復表單為單欄顯示
        const formCol = document.getElementById('formColumn');
        const mapCol = document.getElementById('mapColumn');
        if (formCol) {
            formCol.classList.remove('col-md-6');
            formCol.classList.add('col-md-12');
        }
        if (mapCol) {
            mapCol.classList.add('d-none');
            mapCol.classList.remove('col-md-6');
        }

        const wrapper = document.querySelector('.basic-form');
        if (wrapper) wrapper.classList.remove('wide');
    }

    // =========================================================
    // 3-5. 若起點 / 終點是地圖選點，說明欄位改成必填
    // =========================================================
    function checkMapPointDescription() {
        const origin = document.getElementById('originInput').value;
        const dest = document.getElementById('destinationInput').value;
        const hasMapPoint = origin === '地圖選點' || dest === '地圖選點';

        // 如果使用者只是用地圖點選而沒有具體地址，
        // 就要求在說明欄位補充實際起訖點。
        const descInput = document.getElementById('descriptionInput');
        if (hasMapPoint) {
            document.getElementById('descriptionLabel').textContent = '說明（必填）';
            descInput.required = true;
            descInput.placeholder = '請填寫實際起訖點說明';
            document.getElementById('mapPointHint').style.display = '';
        } else if (currentCategoryCode !== 'Other') {
            document.getElementById('descriptionLabel').textContent = '說明（選填）';
            descInput.required = false;
            descInput.placeholder = '';
            document.getElementById('mapPointHint').style.display = 'none';
        }
    }

    // =========================================================
    // 3-6. 地址轉座標：呼叫 OpenStreetMap Nominatim
    // =========================================================
    async function geocodeAddress(type) {
        const input = type === 'origin' ? document.getElementById('originInput') : document.getElementById('destinationInput');
        const address = input.value.trim();
        if (!address) return confirmModal.showAlert('請輸入地址');

        try {
            // 打的是本站 API，不是直接打外部 Nominatim。
            const resp = await fetch(`/api/expense/geocode?address=${encodeURIComponent(address)}`);
            const payload = await resp.json();
            if (!resp.ok || !payload.success || !payload.data) {
                confirmModal.showAlert(payload?.error?.message || '找不到此地址，請在地圖上直接點擊設定');
                return;
            }

            const latlng = L.latLng(payload.data.latitude, payload.data.longitude);
            setPoint(type, latlng, payload.data.displayName);
        } catch (e) {
            confirmModal.showAlert('定位失敗，請在地圖上直接點擊設定');
        }
    }

    // =========================================================
    // 3-7. 設定起點或終點
    // =========================================================
    function setPoint(type, latlng, name) {
        if (type === 'origin') {
            if (originMarker) map.removeLayer(originMarker);
            originMarker = L.marker(latlng, { title: '起點' }).addTo(map).bindPopup('起點: ' + name);
            originCoords = latlng;

            // 同步寫進 hidden input，讓送表單時後端拿得到這組座標。
            setCoordinateInputs('origin', latlng);
            if (!document.getElementById('originInput').value || document.getElementById('originInput').value === '地圖選點') {
                document.getElementById('originInput').value = name;
            }
        } else {
            if (destMarker) map.removeLayer(destMarker);
            destMarker = L.marker(latlng, { title: '終點' }).addTo(map).bindPopup('終點: ' + name);
            destCoords = latlng;
            setCoordinateInputs('destination', latlng);
            if (!document.getElementById('destinationInput').value || document.getElementById('destinationInput').value === '地圖選點') {
                document.getElementById('destinationInput').value = name;
            }
        }

        // 地圖移到新設定的點附近
        map.setView(latlng, 13);
        checkMapPointDescription();
        markRouteStale();
    }

    // =========================================================
    // 3-8. 點地圖後顯示選單：設為起點 / 終點
    // =========================================================
    function showMapPopup(latlng) {
        L.popup()
            .setLatLng(latlng)
            .setContent(`
                <div style="text-align:center">
                    <button type="button" class="btn btn-sm btn-primary mb-1" onclick="setPointFromMap('origin', ${latlng.lat}, ${latlng.lng}); map.closePopup();">設為起點</button><br>
                    <button type="button" class="btn btn-sm btn-danger" onclick="setPointFromMap('destination', ${latlng.lat}, ${latlng.lng}); map.closePopup();">設為終點</button>
                </div>`)
            .openOn(map);
    }

    // =========================================================
    // 3-9. 直接用地圖點選來設定起點 / 終點
    // =========================================================
    function setPointFromMap(type, lat, lng) {
        setPoint(type, L.latLng(lat, lng), '地圖選點');
        if (type === 'origin') {
            document.getElementById('originInput').focus();
        } else {
            document.getElementById('destinationInput').focus();
        }
    }

    // =========================================================
    // 3-10. 計算路線距離：呼叫 OSRM 路線服務
    // =========================================================
    async function calculateRoute() {
        const origin = document.getElementById('originInput').value.trim();
        const destination = document.getElementById('destinationInput').value.trim();
        if (!origin || !destination) {
            confirmModal.showAlert('請先設定起點和終點');
            return;
        }

        try {
            const isRoundTrip = document.getElementById('isRoundTripCheck').checked;

            // 把文字地址、已知座標、是否往返一起送給後端，
            // 由後端統一試算距離與 geometry。
            const resp = await fetch('/api/expense/route-preview', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    origin,
                    destination,
                    originLatitude: originCoords?.lat ?? null,
                    originLongitude: originCoords?.lng ?? null,
                    destinationLatitude: destCoords?.lat ?? null,
                    destinationLongitude: destCoords?.lng ?? null,
                    isRoundTrip
                })
            });

            const payload = await resp.json();
            if (!resp.ok || !payload.success || !payload.data) {
                confirmModal.showAlert(payload?.error?.message || '路線計算失敗，請稍後再試');
                return;
            }

            // 後端已經幫我們整理好單程距離、總距離與 geometry。
            const singleDistanceKm = Number(payload.data.singleDistanceKm);
            const totalDistanceKm = Number(payload.data.totalDistanceKm);

            // 先在前端即時擋下異常長距離，改善使用者體驗；
            // 送單時後端還會再驗證一次。
            if (totalDistanceKm > 1000) {
                document.getElementById('distanceInput').value = '';
                const amountEl = document.getElementById('amountInput');
                if (amountEl && currentItemCode === 'PersonalCar') amountEl.value = '';
                updateRouteInfo('距離異常：單日往返距離超過 1000 公里，請重新定位起訖點並再次計算。', true);
                routeCalculated = false;
                return;
            }

            const totalKmStr = totalDistanceKm.toFixed(1);
            const singleKmStr = singleDistanceKm.toFixed(1);
            document.getElementById('distanceInput').value = totalKmStr;

            // 自用車：前端先即時計算補助金額，
            // 讓使用者送出前就能看到結果。
            if (currentItemCode === 'PersonalCar') {
                document.getElementById('amountInput').value = Math.ceil(totalDistanceKm * carRate);
            }

            if (routeLayer) map.removeLayer(routeLayer);

            if (payload.data.geometry) {
                const routeStyle = isRoundTrip
                    ? { color: '#3388ff', weight: 4, dashArray: '10, 10' }
                    : { color: '#3388ff', weight: 4 };
                routeLayer = L.geoJSON(payload.data.geometry, { style: routeStyle }).addTo(map);
                map.fitBounds(routeLayer.getBounds());
            }

            const arrow = isRoundTrip ? '↔' : '→';
            updateRouteInfo(`單程 ${singleKmStr} km ${arrow} ${isRoundTrip ? '往返' : '單程'} ${totalKmStr} km`, false);
            routeCalculated = true;
        } catch (e) {
            confirmModal.showAlert('路線計算失敗，請稍後再試');
        }
    }

    // =========================================================
    // 3-11. 起點 / 終點變更後，把舊路線標記成失效
    // =========================================================
    function markRouteStale() {
        routeCalculated = false;

        if (routeLayer) {
            try { map.removeLayer(routeLayer); } catch (e) { }
            routeLayer = null;
        }

        // 一旦起終點變更，舊距離就不可信，所以提示重新計算。
        updateRouteInfo('起點或終點已變更，請按「計算路線距離」更新公里數', true);

        // 變更起訖點後，公里數與自用車金額都要重算
        const distInput = document.getElementById('distanceInput');
        if (distInput) distInput.value = '';
        if (currentItemCode === 'PersonalCar') {
            const amountEl = document.getElementById('amountInput');
            if (amountEl) amountEl.value = '';
        }
    }

    // =========================================================
    // 3-12. 送出表單前的前端檢查
    // =========================================================
    document.getElementById('expenseForm')?.addEventListener('submit', function (e) {
        const isDomesticTransport = currentCategoryCode === 'DomesticTransport';

        // 國內交通：必須至少有起點與終點
        if (isDomesticTransport && currentItemCode) {
            const origin = document.getElementById('originInput').value.trim();
            const dest = document.getElementById('destinationInput').value.trim();
            const distanceValue = document.getElementById('distanceInput').value.trim();
            if (!origin || !dest) {
                e.preventDefault();
                confirmModal.showAlert('請輸入起點與終點');
                return;
            }

            // 送單前一定要先算出距離，避免只有填地址但沒真的做試算。
            if (!distanceValue) {
                e.preventDefault();
                confirmModal.showAlert('請先按「計算路線距離」取得公里數');
                return;
            }
        }

        // Other：說明必填
        if (currentCategoryCode === 'Other') {
            const desc = document.getElementById('descriptionInput').value.trim();
            if (!desc) {
                e.preventDefault();
                if (window.jQuery) {
                    try {
                        $('#descriptionInput').valid();
                    } catch (ex) { }
                }
                document.getElementById('descriptionInput').focus();
                return;
            }
        }
    });

    // 把最新座標同步寫到 hidden input。
    // 即使頁面最後是整個 form post 回後端，也能保留這組定位結果。
    function setCoordinateInputs(type, latlng) {
        if (type === 'origin') {
            document.getElementById('originLatitudeInput').value = latlng.lat;
            document.getElementById('originLongitudeInput').value = latlng.lng;
        } else {
            document.getElementById('destinationLatitudeInput').value = latlng.lat;
            document.getElementById('destinationLongitudeInput').value = latlng.lng;
        }
    }

    // 使用者手動修改文字地址時，原本 marker / 座標已不再可信，
    // 所以要連同舊距離一起失效。
    function clearPointSelection(type) {
        if (type === 'origin') {
            originCoords = null;
            document.getElementById('originLatitudeInput').value = '';
            document.getElementById('originLongitudeInput').value = '';
            if (originMarker) {
                map.removeLayer(originMarker);
                originMarker = null;
            }
        } else {
            destCoords = null;
            document.getElementById('destinationLatitudeInput').value = '';
            document.getElementById('destinationLongitudeInput').value = '';
            if (destMarker) {
                map.removeLayer(destMarker);
                destMarker = null;
            }
        }

        markRouteStale();
        checkMapPointDescription();
    }

    // 若表單回傳驗證錯誤，重新 render 後把原本的座標和 marker 還原回來。
    function restoreSavedPoints() {
        const savedOriginLat = parseFloat(document.getElementById('originLatitudeInput').value);
        const savedOriginLng = parseFloat(document.getElementById('originLongitudeInput').value);
        const savedDestLat = parseFloat(document.getElementById('destinationLatitudeInput').value);
        const savedDestLng = parseFloat(document.getElementById('destinationLongitudeInput').value);

        if (!Number.isNaN(savedOriginLat) && !Number.isNaN(savedOriginLng)) {
            setPoint('origin', L.latLng(savedOriginLat, savedOriginLng), document.getElementById('originInput').value || '起點');
        }

        if (!Number.isNaN(savedDestLat) && !Number.isNaN(savedDestLng)) {
            setPoint('destination', L.latLng(savedDestLat, savedDestLng), document.getElementById('destinationInput').value || '終點');
        }
    }

    // 統一更新路線提示區內容與顏色。
    function updateRouteInfo(message, isError) {
        const routeInfoEl = document.getElementById('routeInfo');
        if (!routeInfoEl) return;

        routeInfoEl.style.display = '';
        routeInfoEl.textContent = message;
        routeInfoEl.classList.remove('text-info', 'text-danger');
        routeInfoEl.classList.add(isError ? 'text-danger' : 'text-info');
    }
</script>
