@model List<StarterM.Models.Application>
@{
    ViewData["Title"] = "申請紀錄";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var pendingReviews = ViewData["PendingReviews"] as List<StarterM.Models.Application>;
}

@section Styles {
    <style>
        /* 最後一列底線 */
        .table tbody tr:last-child td {
            border-bottom: 1px solid gray;
        }

        /* 這區塊標題 */
        .section-title {
            font-size: 1.1rem;
            font-weight: 600;
        }

        /* icon 大小 */
        .review-icon {
            font-size: 1.2rem;
        }

        /* 這顆數量 badge */
        .section-badge {
            font-size: 0.85rem;
            font-weight: 500;
            padding: 0.4em 0.6em;
            border-radius: 10px;
        }
    </style>
}

<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h1>
                <i class="text-primary fa-lg mr-2 @(User.IsInRole("Manager") ? "icon icon-check-2" : "icon icon-time")"></i>
                @(User.IsInRole("Manager") ? "差旅審核" : "申請紀錄")
            </h1>      
        </div>
    </div>
</div>


<!-- 待審核（主管才看到） -->
@if (User.IsInRole("Manager"))
{
    @if (pendingReviews != null && pendingReviews.Any())
    {
        <div class="table-responsive">
            <div class="card mb-4">
                <div class="card-header d-flex align-items-center justify-content-between">                    
                    <div class="d-flex align-items-center mb-3">
                        <i class="fas fa-clock text-warning mr-2 review-icon"></i>
                        <span class="section-title">
                            待審核申請單
                        </span>
                        <span class="badge badge-primary section-badge ml-2">
                            @pendingReviews.Count
                        </span>
                    </div>
                </div>              
                <div class="card-body">               
                    <table class="table primary-table-bordered table-hover" id="pendingTable">
                        <thead class="thead-primary">
                            <tr>
                                <th class="text-center">員工</th>
                                <th class="text-center">出差日</th>
                                <th class="text-right">總金額</th>
                                <th class="text-center">送出時間</th>
                                <th class="text-center">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in pendingReviews)
                            {
                                var dates = r.DailyTrips.Select(d => d.Date).OrderBy(d => d).ToList();
                                var dateRange = dates.Any()
                                    ? $"{dates.First():yyyy/MM/dd} ~ {dates.Last():yyyy/MM/dd}"
                                    : "-";
                                var totalAmount = r.DailyTrips.SelectMany(d => d.Expenses).Sum(e => e.Amount);
                                <tr>
                                    <td class="text-center">@r.Employee?.Name</td>
                                    <td class="text-center">@dateRange</td>
                                    <td class="text-right" data-order="@totalAmount">NT$ @totalAmount.ToString("N0")</td>
                                    <td class="text-center">@r.SubmittedAt?.ToString("yyyy/MM/dd HH:mm")</td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="icon icon-check-2"></i> 審核
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {     
        <div class="row justify-content-center mt-4">
            <div class="col-md-8 col-lg-6">
                <div class="alert alert-primary text-center mb-0">
                    <i class="fas fa-info-circle mr-2"></i>                
                    目前暫無待審核資料。                            
                </div>
            </div>
        </div>
    }
}

<!-- 申請紀錄 -->
@if (!User.IsInRole("Manager"))
{     
    
    @if (Model.Any())
    {   
        <div class="table-responsive">             
            <table class="table primary-table-bordered table-hover" id="myReportsTable">
                <thead class="thead-primary">
                    <tr>
                        <th  class="text-left ">申請日</th>
                        <th  class="text-left">出差日</th>
                        <th  class="text-right">總金額</th>
                        <th  class="text-center">狀態</th>
                        <th  class="text-center">操作</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model)
                    {
                        var dates = r.DailyTrips.Select(d => d.Date).OrderBy(d => d).ToList();
                        var dateRange = dates.Any()
                            ? $"{dates.First():yyyy/MM/dd} ~ {dates.Last():yyyy/MM/dd}"
                            : "-";
                        var totalAmount = r.DailyTrips.SelectMany(d => d.Expenses).Sum(e => e.Amount);
                        <tr>
                            <td class="text-left">@r.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd")</td>
                            <td class="text-left">@dateRange</td>
                            <td class="text-right" data-order="@totalAmount">NT$ @totalAmount.ToString("N0")</td>
                            <td class="text-center">
                                @{
                                    var badge = r.Status?.Code switch
                                    {
                                        "Draft" => "badge-secondary",
                                        "Submitted" => "badge-info",
                                        "Approved" => "badge-success",
                                        "Rejected" => "badge-danger",
                                        "Voided" => "badge-dark",
                                        _ => "badge-secondary"
                                    };
                                }
                                <span class="badge @badge">@r.Status?.Name</span>
                            </td>
                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye "></i> 
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {            
        <div class="row justify-content-center mt-4">
            <div class="col-md-8 col-lg-6">
                <div class="alert alert-primary text-center mb-0">
                    <i class="fas fa-info-circle mr-2"></i>                
                    尚無申請紀錄，請至「差旅申請」建立。                            
                </div>
            </div>
        </div>
    }
    
    
}

@section Scripts {
<script>
    $(function () {
        var tables = {};

        function initTable(id, orderCol) {
            var dt = $('#' + id).DataTable({
                pageLength: 5,
                lengthMenu: [5, 10, 25],
                order: [[orderCol ?? 0, 'desc']],
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/zh-HANT.json'
                },
                columnDefs: [
                    { orderable: false, targets: -1 }
                ],
                dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>t<"row"<"col-sm-6"i><"col-sm-6"p>>'
            });
            tables[id] = dt;
        }

        if ($('#pendingTable').length) initTable('pendingTable', 3);
        if ($('#myReportsTable').length) initTable('myReportsTable', 0);
        
    });
</script>
}
