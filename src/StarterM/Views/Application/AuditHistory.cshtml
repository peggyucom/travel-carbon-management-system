@model List<StarterM.Models.Application>
@using StarterM.Models.Enums
@{
    ViewData["Title"] = "審核紀錄";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <style>
        /* 最後一列底線 */
        .table tbody tr:last-child td {
            border-bottom: 1px solid gray;
        }      
    </style>
}


<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h1><i class="text-primary fa-lg mr-2 icon icon-time"></i>審核紀錄</h1>      
        </div>
    </div>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table primary-table-bordered table-hover" id="auditTable">
                    <thead class="thead-primary">
                        <tr>
                            <th class="text-center">審核日</th>
                            <th class="text-center">員工名稱</th>
                            <th class="text-center">出差日</th>
                            <th class="text-right">總金額</th>
                            <th class="text-center">狀態</th>
                            <th class="text-center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            var dates = r.DailyTrips.Select(d => d.Date).OrderBy(d => d).ToList();
                            var dateRange = dates.Any()
                                ? $"{dates.First():yyyy/MM/dd} ~ {dates.Last():yyyy/MM/dd}"
                                : "-";
                            var totalAmount = r.DailyTrips.SelectMany(d => d.Expenses).Sum(e => e.Amount);
                            var reviewDate = r.ApprovalHistories
                                .Where(h => h.Action == ApprovalAction.Approve || h.Action == ApprovalAction.Reject)
                                .OrderByDescending(h => h.CreatedAt)
                                .Select(h => h.CreatedAt.ToLocalTime().ToString("yyyy/MM/dd"))
                                .FirstOrDefault() ?? "-";
                            <tr>
                                <td class="text-center">@reviewDate</td>
                                <td class="text-center">@r.Employee?.Name</td>
                                <td class="text-center">@dateRange</td>
                                <td class="text-right" data-order="@totalAmount">NT$ @totalAmount.ToString("N0")</td>
                                <td class="text-center">
                                    @{
                                        var badge = r.Status?.Code switch
                                        {
                                            "Approved" => "badge-success",
                                            "Rejected" => "badge-danger",
                                            "Voided" => "badge-dark",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge @badge">@r.Status?.Name</span>
                                </td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-id="@r.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="row justify-content-center mt-4">
                <div class="col-md-8 col-lg-6">
                    <div class="alert alert-primary text-center mb-0">
                        <i class="fas fa-info-circle mr-2"></i>                
                        尚無審核紀錄。                            
                    </div>
                </div>
            </div>            
        }
    </div>
</div>

@section Scripts {
<script>
  $(function () {
        var tables = {};

        function initTable(id, orderCol) {
            var dt = $('#' + id).DataTable({
                pageLength: 5,
                lengthMenu: [5, 10, 25],
                order: [[orderCol ?? 0, 'desc']],
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/zh-HANT.json'
                },
                columnDefs: [
                    { orderable: false, targets: -1 }
                ],
                dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>t<"row"<"col-sm-6"i><"col-sm-6"p>>'
            });
            tables[id] = dt;
        }

        if ($('#auditTable').length) initTable('auditTable', 0);     
        
    });

    
</script>
}
