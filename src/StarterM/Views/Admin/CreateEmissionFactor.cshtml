@model StarterM.ViewModels.EmissionFactorViewModel
@{
    ViewData["Title"] = "新增碳排係數";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
 @* 引入flatpickr *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <style>
        /* ===== 表單寬度 ===== */
        .basic-form {
            max-width: 800px;   
            margin: 0 auto;
        }
        /* ===== flatpickr ===== */
        .flatpickr-input {
            background-color: #fff;
        }
    </style>
}

<div class="row page-titles mx-0">
    <div class="col-sm-6 p-md-0">
        <div class="welcome-text">
            <h1><i class="text-primary fa-lg mr-2 fas fa-plus-square"></i>新增碳排係數</h1>      
        </div>
    </div>
</div>
<div class="card">            
    <div class="card-body">
        <div class="basic-form">
            <form asp-action="CreateEmissionFactor" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="VehicleTypeId" type="hidden" />
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="form-group row">
                    <label class="col-sm-2 col-form-label col-form-label-lg" asp-for="VehicleTypeName">交通工具</label>
                    <div class="col-sm-10 d-flex align-items-center">
                        <input asp-for="VehicleTypeName" class="form-control form-control-lg" readonly />
                    </div>
                </div>
                <div class="form-group row">
                    <label  class="col-sm-2 col-form-label col-form-label-lg" asp-for="Co2PerKm">碳排係數 (kgCO₂/km)</label>
                    <div class="col-sm-10 d-flex align-items-center">
                        <input asp-for="Co2PerKm" class="form-control form-control-lg" type="number" step="0.0001" min="0.0001" />
                        <span asp-validation-for="Co2PerKm" class="text-danger ml-1">*</span>
                    </div>
                </div>
               <div class="form-group row">
                    <label class="col-sm-2 col-form-label col-form-label-lg" asp-for="EffectiveFrom">生效日期</label>
                    <div class="col-sm-10 d-flex align-items-center">
                        <input asp-for="EffectiveFrom"
                            id="effectiveFrom"
                            class="form-control form-control-lg"
                            type="text"
                            autocomplete="off" />
                        <span asp-validation-for="EffectiveFrom" class="text-danger ml-1">*</span>
                    </div>                    
                </div>
                <div class="form-group row">
                    <div class="col-sm-2">
                    </div>
                    <div class="col-sm-10">
                        <small class="form-text text-muted">
                            可設定 @Model.MinEffectiveFrom.ToString("yyyy-MM-dd") ~ @Model.MaxEffectiveFrom.ToString("yyyy-MM-dd")
                        </small>
                    </div>                        
                </div>
                <div class="form-group row">
                    <label class="col-sm-2 col-form-label col-form-label-lg" asp-for="Source">資料來源</label>
                     <div class="col-sm-10 d-flex align-items-center">
                        <input asp-for="Source" class="form-control form-control-lg" placeholder="例如：環保署公告" />
                        <span asp-validation-for="Source" class="text-danger ml-1">*</span>
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-10 d-flex align-items-center">
                        <button type="submit" class="btn btn-primary mr-2"><i class="fas fa-save mr-1"></i> 儲存</button>
                        <a asp-action="EmissionFactors" class="btn btn-primary">
                            <i class="fas fa-arrow-left mr-1"></i> 返回
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/zh.js"></script>      
    <script>
         $(function () {
            flatpickr("#effectiveFrom", {
                dateFormat: "Y-m-d",
                locale: "zh",
                defaultDate: "@Model.EffectiveFrom.ToString("yyyy-MM-dd")",
                minDate: "@Model.MinEffectiveFrom.ToString("yyyy-MM-dd")",
                maxDate: "@Model.MaxEffectiveFrom.ToString("yyyy-MM-dd")",
                allowInput: true,
                clickOpens: true   
            });
        });
    </script>
}