@model List<StarterM.Models.ExpenseRecord>
@{
    ViewData["Title"] = "員工差旅紀錄";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var employeeName = ViewData["EmployeeName"]?.ToString();
    var employeeEmail = ViewData["EmployeeEmail"]?.ToString();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2><i class="fas fa-list"></i> 員工差旅紀錄</h2>
        <p class="text-muted mb-0">
            <i class="fas fa-user"></i> @employeeName &nbsp;
            <i class="fas fa-envelope"></i> @employeeEmail
        </p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> 返回員工列表
    </a>
</div>

@if (Model.Any())
{
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-dark">
                <tr>
                    <th>日期</th>
                    <th>費用分類</th>
                    <th>費用項目</th>
                    <th class="text-right">金額</th>
                    <th class="text-right">公里數</th>
                    <th>說明</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Date.ToString("yyyy-MM-dd")</td>
                        <td>@(item.ExpenseCategory?.Name ?? "-")</td>
                        <td>@(item.ExpenseItem?.Name ?? "-")</td>
                        <td class="text-right">NT$ @item.Amount.ToString("N0")</td>
                        <td class="text-right">@(item.DistanceKm?.ToString("N1") ?? "-")</td>
                        <td>@(item.Description ?? "-")</td>
                        <td>
                            <a asp-controller="Expense" asp-action="Details" asp-route-id="@item.Id"
                               class="btn btn-sm btn-outline-info">
                                <i class="fas fa-eye"></i> 查看
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted">
        共 @Model.Count 筆，合計金額：
        <strong>NT$ @Model.Sum(r => r.Amount).ToString("N0")</strong>
    </p>
}
else
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> 此員工目前尚無差旅費用紀錄。
    </div>
}
